# ============================================
# NISAAP - Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values
# For Vercel deployment, add these in Vercel Dashboard > Settings > Environment Variables
# ============================================

# ---------- DATABASE (Local Development) ----------
DATABASE_URL=file:./dev.db

# ---------- DATABASE (Production - Turso) ----------
# Get these from https://turso.tech after creating a database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.so
TURSO_AUTH_TOKEN=your-turso-auth-token

# ---------- DRIVER ADAPTER ----------
# Set to "true" when using Turso in production
USE_DRIVER_ADAPTER=true

# ---------- SESSION SECURITY ----------
# Generate a strong secret: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-strong-random-secret

# ---------- NODE ENV ----------
NODE_ENV=production
